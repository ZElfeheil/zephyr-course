mainmenu "My application"

source "Kconfig.zephyr"

menu "App options"

config LED_SUBSYSTEM
	bool "LED Subsystem for toggling"
	default y
	help
	  Enable/Disable LED system for toggling the LED state in the main application.

if LED_SUBSYSTEM

choice
	prompt "LED blink sleep time"
	default BLINK_SLEEP_1000

config BLINK_SLEEP_250
	bool "Fast 250 ms"

config BLINK_SLEEP_1000
	bool "1 sec (Medium)"

config BLINK_SLEEP_2000
	bool "Slow 2 seconds"

endchoice

config BLINK_SLEEP_MS
	int
	default 250 if BLINK_SLEEP_250
	default 1000 if BLINK_SLEEP_1000
	default 2000 if BLINK_SLEEP_2000

menuconfig ADVANCED_LED_SETTINGS
	bool "Advanced LED settings"
	default n

if ADVANCED_LED_SETTINGS

config LED_BRIGHTNESS
	int "LED brightness (0-100)"
	range 0 100
	default 100

config LED_FADE_DURATION_MS
	int "LED Fade Duration (ms)"
	range 0 5000
	default 500

menu "Expert settings"

config LED_DEBUG
	bool "Enable LED debugging"
	default n

config BLINK_PATTERN
	bool "Custom blink pattern"
	default n

endmenu

endif
endif

rsource "Kconfig.heartbeat"

endmenu
